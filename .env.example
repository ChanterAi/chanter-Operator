# CHANTER Operator — environment configuration example.
# Copy to .env and fill in real values. Never commit real tokens.

# Server
OPERATOR_PORT=3001
OPERATOR_DATABASE_PATH=data/operator.sqlite
OPERATOR_AUDIT_PATH=data/audit.jsonl
OPERATOR_WORKSPACE_ROOT=workspace
# OPERATOR_RUNNER_WORKSPACE=/path/to/git/repo

# AutoPoster runtime (optional — fail-closed when absent)
# AUTOPOSTER_BASE_URL=http://localhost:3010
# AUTOPOSTER_RUNTIME_TOKEN=
# OPERATOR_RUNTIME_USER_ID=
# AUTOPOSTER_RUNTIME_TIMEOUT_MS=10000

# Mission submission capability (required only for the two create routes).
# This capability cannot approve, reconcile, resume, stop, or ingest ledger entries.
# Must differ from control, AutoPoster service, and ledger-ingest capabilities.
OPERATOR_MISSION_SUBMIT_TOKEN=

# Independent Operator control capability (required for approve/reconcile/resume/stop).
# Must differ from submit, AutoPoster service, and ledger-ingest capabilities.
# Do not share this value with MCP or other mission-submission clients.
OPERATOR_CONTROL_TOKEN=

# Agent Run Ledger ingest capability token (required for ledger entry submission).
# Must differ from submit, control, and AutoPoster service capabilities.
# When unset or colliding, POST /api/agent-run-ledger/entries returns 503 fail-closed.
OPERATOR_LEDGER_INGEST_TOKEN=
