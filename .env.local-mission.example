# ─────────────────────────────────────────────────────────────────────────
# LOCAL / NON-PRODUCTION ONLY.
#
# Named operational profile for the "persistent AutoPoster product mission"
# capability (tools/local-mission/run-mission.mts). Copy this file to
# .env.local-mission (gitignored) and fill in the placeholder values below.
#
# Never point AUTOPOSTER_BASE_URL at a real deployed AutoPoster instance and
# never set FIREBASE_PROJECT_ID/FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY to
# real production Firebase credentials here. This profile is designed to run
# entirely against loopback processes and the local Firestore emulator.
# ─────────────────────────────────────────────────────────────────────────

# ── Operator ────────────────────────────────────────────────────────────
OPERATOR_PORT=3101
OPERATOR_BASE_URL=http://127.0.0.1:3101
OPERATOR_RUNTIME_PROFILE=local-mission
# A dedicated persistent path — deliberately not the default data/operator.sqlite,
# so this never collides with a founder's own interactive dev database.
OPERATOR_DATABASE_PATH=var/local-mission/operator.sqlite
OPERATOR_AUDIT_PATH=var/local-mission/audit.jsonl
OPERATOR_WORKSPACE_ROOT=var/local-mission/workspace
OPERATOR_EVIDENCE_DIR=var/evidence
OPERATOR_RUNTIME_USER_ID=owner

# Autonomous observation worker — enabled for this profile only (disabled
# everywhere else by default). Poll interval stays >= 1000ms (no busy
# polling); retry delays are shortened from the 15/30/60/120s production
# defaults purely so a local mission converges in seconds, not minutes.
OPERATOR_OBSERVATION_WORKER_ENABLED=true
OPERATOR_OBSERVATION_WORKER_POLL_INTERVAL_MS=2000
OPERATOR_OBSERVATION_WORKER_BATCH_SIZE=4
OPERATOR_OBSERVATION_RETRY_DELAYS_SECONDS=5,10,20,40
OPERATOR_OBSERVATION_LEASE_SECONDS=15
OPERATOR_OBSERVATION_MAX_ATTEMPTS=8
OPERATOR_OBSERVATION_BATCH_SIZE=8

# Independent capability tokens — must all be distinct from each other and
# from AUTOPOSTER_RUNTIME_TOKEN below (Operator fails closed at boot if any
# two collide). Generate with: node -e "console.log(require('crypto').randomUUID())"
OPERATOR_MISSION_SUBMIT_TOKEN=replace-with-a-random-local-submit-token
OPERATOR_CONTROL_TOKEN=replace-with-a-random-local-control-token
OPERATOR_LEDGER_INGEST_TOKEN=replace-with-a-random-local-ledger-token

# ── AutoPoster (real application, Firestore-emulator-backed) ───────────────
AUTOPOSTER_BASE_URL=http://127.0.0.1:3010
# Must exactly match RUNTIME_CONTROL_TOKEN in the AutoPoster process env below.
AUTOPOSTER_RUNTIME_TOKEN=replace-with-a-random-local-runtime-token
AUTOPOSTER_RUNTIME_TIMEOUT_MS=10000

# ─────────────────────────────────────────────────────────────────────────
# The following vars belong to the real AutoPoster server process
# (apps/chanter-auto-poster), which the runner spawns with its own
# environment merged from these values. Kept in this one file for a single
# source of truth for the whole local-mission profile.
# ─────────────────────────────────────────────────────────────────────────
AUTOPOSTER_PORT=3010
AUTOPOSTER_APP_URL=http://localhost:3010
# Must exactly match AUTOPOSTER_RUNTIME_TOKEN above.
AUTOPOSTER_RUNTIME_CONTROL_TOKEN=replace-with-a-random-local-runtime-token
# Any local-only password >= 12 characters; never a real credential.
AUTOPOSTER_ADMIN_PASSWORD=replace-with-a-local-only-password-12chars
AUTOPOSTER_APP_DEFAULT_USER_ID=owner

# Firestore Local Emulator Suite — never a real GCP project. The emulator
# does not validate these credentials; they only need to be well-formed.
# Generate a throwaway keypair with:
#   node -e "const c=require('crypto');console.log(c.generateKeyPairSync('rsa',{modulusLength:2048,privateKeyEncoding:{type:'pkcs8',format:'pem'},publicKeyEncoding:{type:'spki',format:'pem'}}).privateKey.replace(/\n/g,'\\n'))"
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_PROJECT_ID=chanter-autoposter-local
FIREBASE_CLIENT_EMAIL=local-mission@chanter-autoposter-local.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=replace-with-a-throwaway-pem-private-key

# Provider kill switches — explicit, belt-and-suspenders publishing safety
# on top of the structural guarantees already proven in the task's evidence
# (external-cron-only scheduler, AutoPoster's own Release Queue approval
# gate). Leaving OAuth client vars blank means neither provider's real API
# can ever be reached even if something tried.
YOUTUBE_ENABLED=false
ENABLE_INSTAGRAM=false
INSTAGRAM_PUBLISH_ENABLED=false

# ── Firestore emulator process (spawned by the runner if not already up) ──
FIRESTORE_EMULATOR_PROJECT=chanter-autoposter-local
FIRESTORE_EMULATOR_DATA_DIR=var/local-mission/firestore-data
