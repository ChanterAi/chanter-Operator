{
  "name": "chanter-operator",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first founder cockpit for reviewable operator workflows.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm run dev --workspace @chanter/operator-backend\" \"npm run dev --workspace @chanter/operator-frontend\"",
    "build": "npm run build --workspace @chanter/operator-backend && npm run build --workspace @chanter/operator-frontend",
    "test": "npm run test --workspace @chanter/operator-backend && npm run test --workspace @chanter/operator-frontend",
    "test:backend": "npm run test --workspace @chanter/operator-backend",
    "test:frontend": "npm run test --workspace @chanter/operator-frontend",
    "typecheck": "npm run typecheck --workspace @chanter/operator-backend && npm run typecheck --workspace @chanter/operator-frontend",
    "release:scan": "node tools/release-operator/release-operator.mjs scan",
    "release:report": "node tools/release-operator/release-operator.mjs report",
    "release:gates": "node tools/release-operator/release-operator.mjs gates",
    "release:test": "node --test \"tools/release-operator/tests/*.test.mjs\"",
    "mission:compile": "node tools/mission-compiler/mission-compiler.mjs",
    "mission:test": "node --test \"tools/mission-compiler/tests/*.test.mjs\"",
    "test:agent-run-ledger:cross-repo": "node tools/resilience-evidence/clean-source-validation.mjs -- node --import tsx tools/agent-run-ledger/cross-repository-demo.mjs",
    "test:phase2b1:ledger": "node --import tsx --test tools/phase2b1/ledger-transport.integration.test.mts",
    "test:phase2b2:ledger": "node --import tsx --test tools/phase2b2/ledger-durable-ingest.integration.test.mts",
    "test:phase2c:mission": "node --import tsx --test tools/phase2c/mission-loop.integration.test.mts",
    "test:phase2d:graph": "node --import tsx --test tools/phase2d/mission-graph.integration.test.mts",
    "test:phase2e:autoposter-graph": "node --import tsx --test tools/phase2e/autoposter-schedule-graph.integration.test.mts",
    "test:phase2eb:autoposter-results": "node --import tsx --test tools/phase2e/autoposter-result-refresh.integration.test.mts",
    "test:phase2f:unified-ingress": "node --import tsx --test tools/phase2f/autoposter-unified-ingress.integration.test.mts",
    "test:safecommit-closeout": "npm run test --workspace @chanter/operator-backend -- --run tests/safecommit-closeout.test.ts tests/safecommit-closeout-migration.test.ts tests/capabilityToken.test.ts",
    "test:safecommit-closeout:e2e": "node --import tsx --test tools/safecommit-closeout/safecommit-closeout.integration.test.mts",
    "test:resilience:cross-process": "node tools/resilience-evidence/clean-source-validation.mjs",
    "test:runtime:clean-source": "node tools/resilience-evidence/clean-source-validation.mjs --runtime-tests"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
